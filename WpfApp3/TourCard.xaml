<UserControl x:Class="WpfApp3.TourCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp3"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="400">
    <Grid>
        <Image x:Name="ImageTour" HorizontalAlignment="Left" Height="100" Margin="10,10,0,0" VerticalAlignment="Top" Width="100"/>
        <TextBlock HorizontalAlignment="Left" Margin="125,10,0,0" TextWrapping="Wrap" Text="{Binding NameTour}" VerticalAlignment="Top" Width="130" Height="30"/>
        <TextBlock HorizontalAlignment="Left" Margin="125,80,0,0" TextWrapping="Wrap" Text="{Binding Duration}" VerticalAlignment="Top" Width="130" Height="30"/>
        <TextBlock HorizontalAlignment="Left" Margin="125,45,0,0" TextWrapping="Wrap" Text="{Binding Country}" VerticalAlignment="Top" Width="130" Height="30"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,210,0,0" TextWrapping="Wrap" Text="{Binding StartDate}" VerticalAlignment="Top" Width="130" Height="30"/>
        <TextBlock HorizontalAlignment="Left" Margin="260,10,0,0" TextWrapping="Wrap" Text="{Binding Cost}" VerticalAlignment="Top" Width="130" Height="30"/>
        <TextBlock HorizontalAlignment="Left" Margin="260,40,0,0" TextWrapping="Wrap" Text="{Binding FreeSeats}" VerticalAlignment="Top" Width="130" Height="30"/>

    </Grid>
</UserControl>
