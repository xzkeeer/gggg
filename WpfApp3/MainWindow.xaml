<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl Margin="10">
        <TabItem Header="Тур">
            <ListView x:Name="TourListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <local:TourCard/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </TabItem>
        <TabItem Header="Заявки" x:Name="RequestTabItem">
            <ListView x:Name="RequestListView">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="№" DisplayMemberBinding="{Binding Id}" Width="45"/>
                        <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding Users.FullNameUsers}" Width="150"/>
                        <GridViewColumn Header="Тур" DisplayMemberBinding="{Binding Tours.NameTour}" Width="150"/>
                        <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding DateStart, StringFormat='dd.MM.yyyy'}" Width="100"/>
                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding StatusrRequest.Name}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </TabItem>
    </TabControl>
</Window>
